<mujoco model="panda_pick_place_scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.5" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="640" offheight="480"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.55 0.38 0.22 1" specular="0.2" shininess="0.2"/>
    <material name="shelf_mat" rgba="0.45 0.45 0.5 1" specular="0.3" shininess="0.3"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true" castshadow="true"/>
    <light pos="1.5 -1.5 2" dir="-0.5 0.5 -1" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>

    <geom name="floor" type="plane" size="0 0 0.05" material="groundplane"/>

    <!-- Table: top surface at z=0.4, arm base sits on it -->
    <geom name="table" type="box" pos="0.3 0 0.2" size="0.5 0.5 0.2" material="table_mat"/>

    <!-- Pickable colored boxes (4cm cubes) resting on the tabletop -->
    <body name="box_red" pos="0.5 0 0.42">
      <freejoint name="box_red_free"/>
      <geom name="box_red_geom" type="box" size="0.02 0.02 0.02" rgba="0.8 0.1 0.1 1"
        mass="0.05" friction="1 0.005 0.0001"/>
    </body>
    <body name="box_green" pos="0.45 -0.15 0.42">
      <freejoint name="box_green_free"/>
      <geom name="box_green_geom" type="box" size="0.02 0.02 0.02" rgba="0.1 0.7 0.1 1"
        mass="0.05" friction="1 0.005 0.0001"/>
    </body>
    <body name="box_blue" pos="0.55 0.12 0.42">
      <freejoint name="box_blue_free"/>
      <geom name="box_blue_geom" type="box" size="0.02 0.02 0.02" rgba="0.1 0.2 0.85 1"
        mass="0.05" friction="1 0.005 0.0001"/>
    </body>
    <body name="box_yellow" pos="0.38 0.12 0.42">
      <freejoint name="box_yellow_free"/>
      <geom name="box_yellow_geom" type="box" size="0.02 0.02 0.02" rgba="0.9 0.85 0.1 1"
        mass="0.05" friction="1 0.005 0.0001"/>
    </body>

    <!-- Shelf: thin plate ~0.25m above the tabletop, off to one side -->
    <geom name="shelf" type="box" pos="0.35 0.4 0.65" size="0.15 0.12 0.01" material="shelf_mat"/>
    <geom name="shelf_post" type="box" pos="0.35 0.51 0.525" size="0.15 0.01 0.125" material="shelf_mat"/>

    <!-- Fixed 3/4 front camera looking at the workspace -->
    <camera name="front_34" pos="1.4 -1.0 1.2" xyaxes="0.673 0.740 0 -0.315 0.287 0.905"/>
  </worldbody>

  <equality>
    <weld name="grasp_weld" body1="hand" body2="box_red" active="false" solref="0.002 1"/>
  </equality>

  <keyframe>
    <key name="home"
      qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04
            0.5 0 0.42 1 0 0 0
            0.45 -0.15 0.42 1 0 0 0
            0.55 0.12 0.42 1 0 0 0
            0.38 0.12 0.42 1 0 0 0"
      ctrl="0 0 0 -1.57079 0 1.57079 -0.7853 255"/>
  </keyframe>
</mujoco>
